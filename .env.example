# Copy this file to .env and fill in your CryptoQuant API key.
# Pro tier minimum — some indicators require Premium.
CRYPTOQUANT_API_KEY=

# Coinglass v4 API key. Hobbyist tier ($29/mo) gives 80+ endpoints and
# 30 req/min — sufficient for the derivatives section + collector cycles.
# Without this key, the dashboard still loads; only Coinglass-derived tiles
# show "—" and the source bar marks them red.
COINGLASS_API_KEY=

# Backend port (frontend dev proxy targets this).
PORT=8787

# SQLite file path. Used only if collector is running. Optional.
DB_PATH=./data/liquidity.db
